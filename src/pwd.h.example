// Copy this file to pwd.h and fill in your values.
// pwd.h is gitignored — never commit real credentials or IPs.

// ── WiFi credentials ──────────────────────────────────────────────────────────
const char* ssid     = "your-ssid";
const char* password = "your-password";

// ── Home automation server (for offline buffer sync) ─────────────────────────
#define SERVER_IP   "your-server-ip"
#define SERVER_PORT 8000

// ── Preferred AP BSSID (optional: forces connection to a specific AP/extender) ─
// Comment out or set to all-zeros to connect to any AP matching the SSID.
static uint8_t extender_bssid[] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };

// ── Static network config ─────────────────────────────────────────────────────
// Define each address as four comma-separated octets.
#define DEVICE_IP   10,  0,  0,  1    // IP assigned to this device
#define GATEWAY_IP  10,  0,  0,  1    // Router / default gateway
#define SUBNET_MASK 255, 255, 255, 0
